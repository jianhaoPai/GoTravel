.home {
  padding-bottom: 48rpx;
}

.hero {
  min-height: 260rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0f766e, #164e63 62%, #7c2d12);
}

.hero-main {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.eyebrow {
  font-size: 24rpx;
  opacity: 0.86;
}

.title {
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.share-button {
  width: 132rpx;
  height: 72rpx;
  flex: 0 0 auto;
  color: #0f766e;
  background: #ffffff;
  font-weight: 800;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
}

.create-box {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.create-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.create-title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 900;
}

.input-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.input-grid input {
  height: 72rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d8dee8;
  border-radius: 8rpx;
  color: #172033;
  background: #f8fafc;
  font-size: 25rpx;
}

.input-grid input:first-child {
  grid-column: span 2;
}

.member-row,
.filter-row {
  width: 100%;
  white-space: nowrap;
}

.member-chip,
.filter-chip {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  height: 72rpx;
  margin-right: 14rpx;
  padding: 0 22rpx;
  border: 1rpx solid #d8dee8;
  border-radius: 8rpx;
  color: #334155;
  background: #ffffff;
  font-size: 26rpx;
}

.member-chip.active,
.filter-chip.active {
  border-color: #0f766e;
  color: #0f766e;
  background: #e7f4f1;
  font-weight: 800;
}

.avatar {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 30rpx;
}

.summary-item {
  padding: 22rpx 18rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.summary-value {
  display: block;
  color: #0f172a;
  font-size: 42rpx;
  font-weight: 900;
}

.summary-label {
  display: block;
  margin-top: 6rpx;
  color: #64748b;
  font-size: 24rpx;
}

.place-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.inline-title {
  margin-bottom: 0;
}

.mini-button {
  width: 160rpx;
  height: 64rpx;
  color: #ffffff;
  background: #0f766e;
  font-size: 24rpx;
  font-weight: 800;
}

.place-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  background: #ffffff;
}

.place-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.place-name {
  display: block;
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 900;
}

.place-address {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.place-owner {
  min-width: 88rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  border-radius: 24rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.place-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 700;
}

.place-note {
  display: block;
  margin-top: 14rpx;
  color: #334155;
  font-size: 26rpx;
  line-height: 1.5;
}
