<view class="page place-page">
  <view class="place-hero">
    <view class="owner-pill" style="background: {{place.creatorColor}}">{{place.creatorName}}收藏</view>
    <text class="place-title">{{place.name}}</text>
    <text class="place-address">{{place.address}}</text>
    <view class="meta-row">
      <text>{{place.category}}</text>
      <text>{{place.wantCount}} 人想去</text>
      <text>{{place.statusText}}</text>
    </view>
  </view>

  <view class="button-row">
    <button class="primary-button" bindtap="toggleWant">我也想去</button>
    <button class="secondary-button" bindtap="openLocation">导航</button>
  </view>

  <text class="section-title">备注</text>
  <view class="note-box">{{place.note || '暂无备注'}}</view>

  <text class="section-title">讨论</text>
  <view wx:if="{{comments.length}}">
    <view class="comment" wx:for="{{comments}}" wx:key="_id">
      <view class="comment-avatar" style="background: {{item.creatorColor}}">{{item.creatorInitial}}</view>
      <view class="comment-body">
        <view class="comment-top">
          <text class="comment-name">{{item.creatorName}}</text>
          <text class="comment-time">{{item.createdAt}}</text>
        </view>
        <text class="comment-content">{{item.content}}</text>
      </view>
    </view>
  </view>
  <view wx:else class="empty">还没有讨论，先在群里喊一声也行</view>
</view>
