.map-page {
  position: relative;
  height: 100vh;
  overflow: hidden;
}

.trip-map {
  width: 100%;
  height: 100vh;
}

.map-panel {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 28rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 54rpx rgba(15, 23, 42, 0.18);
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.panel-title {
  display: block;
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 900;
}

.panel-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #64748b;
  font-size: 24rpx;
}

.add-button {
  width: 128rpx;
  height: 68rpx;
  color: #ffffff;
  background: #0f766e;
  font-size: 24rpx;
  font-weight: 800;
}

.category-strip,
.place-strip {
  width: 100%;
  white-space: nowrap;
}

.category-strip {
  margin-top: 18rpx;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  margin-right: 12rpx;
  padding: 0 22rpx;
  border: 1rpx solid #d8dee8;
  border-radius: 8rpx;
  color: #334155;
  background: #ffffff;
  font-size: 24rpx;
}

.category-chip.active {
  border-color: #0f766e;
  color: #0f766e;
  background: #e7f4f1;
  font-weight: 800;
}

.place-strip {
  margin-top: 18rpx;
}

.mini-card {
  width: 330rpx;
  display: inline-flex;
  flex-direction: column;
  gap: 8rpx;
  margin-right: 14rpx;
  padding: 18rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  background: #ffffff;
  vertical-align: top;
}

.mini-owner {
  min-width: 72rpx;
  max-width: 140rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  border-radius: 21rpx;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
}

.mini-name {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-meta {
  color: #64748b;
  font-size: 22rpx;
}
