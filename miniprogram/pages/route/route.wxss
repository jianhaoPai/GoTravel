.route-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #164e63;
}

.route-title {
  display: block;
  font-size: 38rpx;
  font-weight: 900;
}

.route-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.88;
}

.save-button {
  width: 116rpx;
  height: 68rpx;
  flex: 0 0 auto;
  color: #164e63;
  background: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.compact {
  min-height: 72rpx;
}

.route-item {
  min-height: 142rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 14rpx;
  padding: 20rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  background: #ffffff;
}

.step-index {
  width: 56rpx;
  height: 56rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  background: #0f766e;
  font-size: 26rpx;
  font-weight: 900;
}

.route-body {
  min-width: 0;
  flex: 1;
}

.route-place-name {
  display: block;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 900;
}

.route-address,
.candidate-note {
  display: block;
  margin-top: 6rpx;
  color: #64748b;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.route-meta {
  display: flex;
  gap: 14rpx;
  margin-top: 10rpx;
  color: #0f766e;
  font-size: 23rpx;
  font-weight: 700;
}

.sort-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sort-actions button {
  width: 56rpx;
  height: 50rpx;
  color: #334155;
  background: #f1f5f9;
  font-size: 26rpx;
  font-weight: 900;
}

.nav-button {
  margin-top: 24rpx;
}

.candidate {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 14rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.candidate-name {
  display: block;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
}

.add-button,
.remove-button {
  width: 110rpx;
  height: 62rpx;
  flex: 0 0 auto;
  font-size: 23rpx;
  font-weight: 800;
}

.add-button {
  color: #ffffff;
  background: #0f766e;
}

.remove-button {
  color: #b45309;
  background: #fff7ed;
}
